# ========================
# ChronoExam Environment Variables
# ========================

# Server
PORT=8000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://mongo:27017/chronoexam
# For local development (without Docker):
# MONGODB_URI=mongodb://localhost:27017/chronoexam

# JWT Authentication
JWT_SECRET=chronoexam-secret-key-change-in-production
JWT_EXPIRY=7d

# Client
REACT_APP_API_URL=http://localhost:8000

# Email (Optional — for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
